# --- App ---
ENVIRONMENT=development
SECRET_KEY=change-me

# --- Database (Supabase Postgres connection string) ---
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# --- Redis (sessions, rate limiting, job queue) ---
REDIS_URL=redis://localhost:6379/0

# --- Supabase Auth ---
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# --- AI Providers ---
# NEVER commit a real key. Rotate any key that has ever been pasted into
# a chat, ticket, or shared document before using it here.
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Voice ---
WHISPER_PROVIDER=openai   # openai | deepgram | assemblyai | elevenlabs
VOICE_STT_API_KEY=
VOICE_TTS_API_KEY=

# --- Code execution ---
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=

# --- Media ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- YouTube ---
YOUTUBE_DATA_API_KEY=
